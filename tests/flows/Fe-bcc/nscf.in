&control
  calculation = 'nscf'
  prefix = 'Fe_bcc'
  outdir = './out'
  pseudo_dir = './pseudo'
/
&system
  ibrav = 0
  nat = 2
  ntyp = 1
  ecutwfc = 40.0
  occupations = 'smearing'
  degauss = 0.02
  nbnd = 16
/
&electrons
  conv_thr = 1.0d-8
/

CELL_PARAMETERS angstrom
  3.430000 0.000000 0.000000
  0.000000 3.430000 0.000000
  0.000000 0.000000 3.430000

ATOMIC_SPECIES
 Fe 55.845 Fe.pseudo.UPF

ATOMIC_POSITIONS angstrom
 Fe 0.000000 0.000000 0.000000
 Fe 1.715000 1.715000 1.715000

K_POINTS automatic
 16 16 16 0 0 0
